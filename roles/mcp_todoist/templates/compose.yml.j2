---
services:
  mcp-todoist:
    image: "{{ chimerai_mcp_todoist_image }}"
    container_name: "{{ chimerai_mcp_todoist_project_name }}"
    restart: unless-stopped
    env_file:
      - .env
    environment:
      HOME: /home/node
      NPM_CONFIG_CACHE: /home/node/.npm
      TZ: "{{ chimerai_timezone }}"
    working_dir: /home/node
    user: "node"
    command:
      - sh
      - -c
      - npx -y -p @doist/todoist-ai@{{ chimerai_mcp_todoist_package_version }} todoist-ai-http
    ports:
      - "{{ chimerai_mcp_todoist_host }}:{{ chimerai_mcp_todoist_host_port }}:{{ chimerai_mcp_todoist_container_port }}"
    volumes:
      - "{{ chimerai_mcp_todoist_npm_cache_dir }}:/home/node/.npm"
    healthcheck:
      test:
        - CMD
        - node
        - -e
        - "fetch('http://127.0.0.1:{{ chimerai_mcp_todoist_container_port }}/health').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 30s
    networks:
      - "{{ chimerai_mcp_todoist_network }}"

networks:
  {{ chimerai_mcp_todoist_network }}:
    external: true
