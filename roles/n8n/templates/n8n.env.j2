DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE={{ chimerai_n8n_db_name }}
DB_POSTGRESDB_USER={{ chimerai_n8n_db_user }}
DB_POSTGRESDB_PASSWORD={{ chimerai_n8n_postgres_password }}
N8N_ENCRYPTION_KEY={{ chimerai_n8n_encryption_key }}
N8N_HOST={{ chimerai_n8n_public_host }}
N8N_PORT={{ chimerai_n8n_container_port }}
N8N_PROTOCOL={{ chimerai_n8n_protocol }}
N8N_SECURE_COOKIE={{ 'true' if chimerai_n8n_secure_cookie | bool else 'false' }}
{% if chimerai_n8n_webhook_url | length > 0 %}
WEBHOOK_URL={{ chimerai_n8n_webhook_url }}
{% endif %}
